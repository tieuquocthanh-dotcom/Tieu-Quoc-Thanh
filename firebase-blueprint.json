{
  "entities": {
    "Manufacturer": {
      "title": "Manufacturer",
      "description": "Hãng sản xuất sản phẩm",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Supplier": {
      "title": "Supplier",
      "description": "Nhà cung cấp hàng hóa",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "contactPerson": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Warehouse": {
      "title": "Warehouse",
      "description": "Kho lưu trữ hàng hóa",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Khách hàng mua hàng",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "email": { "type": "string" },
        "type": { "type": "string", "enum": ["retail", "wholesale"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "type", "createdAt"]
    },
    "Shipper": {
      "title": "Shipper",
      "description": "Đơn vị vận chuyển",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "PaymentMethod": {
      "title": "PaymentMethod",
      "description": "Phương thức thanh toán (Tiền mặt, Chuyển khoản...)",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdAt"]
    },
    "PaymentLog": {
      "title": "PaymentLog",
      "description": "Lịch sử giao dịch tài chính",
      "type": "object",
      "properties": {
        "paymentMethodId": { "type": "string" },
        "paymentMethodName": { "type": "string" },
        "type": { "type": "string", "enum": ["deposit", "withdraw", "transfer_in", "transfer_out"] },
        "amount": { "type": "number" },
        "balanceAfter": { "type": "number" },
        "relatedId": { "type": "string" },
        "relatedType": { "type": "string", "enum": ["sale", "receipt"] },
        "debtorId": { "type": "string" },
        "debtorName": { "type": "string" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" }
      },
      "required": ["paymentMethodId", "type", "amount", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Thông tin sản phẩm",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "importPrice": { "type": "number" },
        "sellingPrice": { "type": "number" },
        "warningThreshold": { "type": "number" },
        "outsideStockWarningThreshold": { "type": "number" },
        "manufacturerId": { "type": "string" },
        "manufacturerName": { "type": "string" },
        "totalInvoicedStock": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isCombo": { "type": "boolean" },
        "comboItems": { "type": "array", "items": { "type": "object" } },
        "isSuspended": { "type": "boolean" }
      },
      "required": ["name", "importPrice", "sellingPrice", "createdAt"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Đơn hàng bán ra",
      "type": "object",
      "properties": {
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "shippingFee": { "type": "number" },
        "amountPaid": { "type": "number" },
        "paymentHistory": { "type": "array", "items": { "type": "object" } },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "warehouseId": { "type": "string" },
        "warehouseName": { "type": "string" },
        "paymentMethodId": { "type": "string" },
        "paymentMethodName": { "type": "string" },
        "shipperId": { "type": "string" },
        "shipperName": { "type": "string" },
        "status": { "type": "string", "enum": ["paid", "debt"] },
        "paidAt": { "type": "string", "format": "date-time" },
        "shippingStatus": { "type": "string", "enum": ["none", "pending", "shipped", "order"] },
        "shippingPayer": { "type": "string", "enum": ["shop", "customer"] },
        "hasReturn": { "type": "boolean" },
        "issueInvoice": { "type": "boolean" },
        "isSaved": { "type": "boolean" },
        "shippedAt": { "type": "string", "format": "date-time" },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" }
      },
      "required": ["items", "total", "warehouseId", "status", "createdAt"]
    },
    "GoodsReceipt": {
      "title": "GoodsReceipt",
      "description": "Đơn nhập hàng",
      "type": "object",
      "properties": {
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "warehouseId": { "type": "string" },
        "warehouseName": { "type": "string" },
        "paymentMethodId": { "type": "string" },
        "paymentMethodName": { "type": "string" },
        "paymentStatus": { "type": "string", "enum": ["paid", "debt"] },
        "hasInvoice": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "paidAt": { "type": "string", "format": "date-time" },
        "invoiceReceivedAt": { "type": "string", "format": "date-time" },
        "amountPaid": { "type": "number" },
        "paymentHistory": { "type": "array", "items": { "type": "object" } },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" }
      },
      "required": ["items", "total", "supplierId", "warehouseId", "paymentStatus", "createdAt"]
    },
    "WarehouseTransfer": {
      "title": "WarehouseTransfer",
      "description": "Lệnh chuyển kho",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "fromWarehouseId": { "type": "string" },
        "fromWarehouseName": { "type": "string" },
        "toWarehouseId": { "type": "string" },
        "toWarehouseName": { "type": "string" },
        "quantity": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" }
      },
      "required": ["productId", "fromWarehouseId", "toWarehouseId", "quantity", "createdAt"]
    },
    "AppUser": {
      "title": "AppUser",
      "description": "Người dùng hệ thống",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "staff"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role", "createdAt"]
    },
    "ChinaImport": {
      "title": "ChinaImport",
      "description": "Đơn nhập hàng Trung Quốc",
      "type": "object",
      "properties": {
        "orderName": { "type": "string" },
        "importDate": { "type": "string", "format": "date-time" },
        "items": { "type": "array", "items": { "type": "object" } },
        "exchangeRate": { "type": "number" },
        "shippingFeeCN": { "type": "number" },
        "shippingFeeVN": { "type": "number" },
        "shippingFeeExtra": { "type": "number" },
        "currencyExchangeFee": { "type": "number" },
        "totalCostCNY": { "type": "number" },
        "totalCostVND": { "type": "number" },
        "status": { "type": "string", "enum": ["ordered", "placed", "paid", "at_vn", "received_full", "received_missing"] },
        "note": { "type": "string" },
        "trackingNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "paymentMethodId": { "type": "string" },
        "paymentMethodName": { "type": "string" }
      },
      "required": ["importDate", "items", "exchangeRate", "createdAt"]
    },
    "PlannedOrder": {
      "title": "PlannedOrder",
      "description": "Dự kiến đặt hàng",
      "type": "object",
      "properties": {
        "supplierId": { "type": "string" },
        "supplierName": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "status": { "type": "string", "enum": ["pending", "ordered", "shipped", "received_full", "received_missing"] },
        "note": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" }
      },
      "required": ["supplierId", "items", "createdAt"]
    },
    "Note": {
      "title": "Note",
      "description": "Ghi chú hệ thống",
      "type": "object",
      "properties": {
        "content": { "type": "string" },
        "status": { "type": "string", "enum": ["khởi tạo", "đã xong", "Có vấn đề"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" }
      },
      "required": ["content", "createdAt"]
    },
    "SavingsBook": {
      "title": "SavingsBook",
      "description": "Sổ tiết kiệm",
      "type": "object",
      "properties": {
        "amount": { "type": "number" },
        "depositDate": { "type": "string", "format": "date-time" },
        "maturityDate": { "type": "string", "format": "date-time" },
        "bankName": { "type": "string" },
        "note": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "closed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" },
        "creatorName": { "type": "string" }
      },
      "required": ["amount", "depositDate", "maturityDate", "bankName", "status", "createdAt"]
    }
  },
  "firestore": {
    "/manufacturers": { "schema": "Manufacturer", "description": "Danh sách hãng sản xuất" },
    "/suppliers": { "schema": "Supplier", "description": "Danh sách nhà cung cấp" },
    "/warehouses": { "schema": "Warehouse", "description": "Danh sách kho hàng" },
    "/customers": { "schema": "Customer", "description": "Danh sách khách hàng" },
    "/shippers": { "schema": "Shipper", "description": "Danh sách đơn vị vận chuyển" },
    "/paymentMethods": { "schema": "PaymentMethod", "description": "Danh sách phương thức thanh toán" },
    "/paymentLogs": { "schema": "PaymentLog", "description": "Lịch sử giao dịch tài chính" },
    "/products": { "schema": "Product", "description": "Danh sách sản phẩm" },
    "/sales": { "schema": "Sale", "description": "Danh sách đơn hàng bán" },
    "/goodsReceipts": { "schema": "GoodsReceipt", "description": "Danh sách đơn nhập hàng" },
    "/transfers": { "schema": "WarehouseTransfer", "description": "Lịch sử chuyển kho" },
    "/users": { "schema": "AppUser", "description": "Danh sách người dùng hệ thống" },
    "/chinaImports": { "schema": "ChinaImport", "description": "Danh sách nhập hàng Trung Quốc" },
    "/plannedOrders": { "schema": "PlannedOrder", "description": "Danh sách dự kiến đặt hàng" },
    "/notes": { "schema": "Note", "description": "Ghi chú hệ thống" },
    "/savings": { "schema": "SavingsBook", "description": "Danh sách sổ tiết kiệm" }
  }
}
